{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ffmpeg_desktop",
  "version": "0.1.4",
  "identifier": "com.william.ffmpeg-desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ffmpeg_desktop",
        "width": 1500,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 700,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://asset.localhost data: blob:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.github.com https://gitee.com; media-src 'self' https://asset.localhost blob:; worker-src 'self' blob:;"
    }
  },
  "plugins": {
    "fs": {}
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/256x256@2x.png",
      "icons/512x512.png",
      "icons/512x512@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "config/*"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
