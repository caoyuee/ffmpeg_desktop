{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ffmpeg_desktop",
  "version": "0.1.6",
  "identifier": "com.william.ffmpeg-desktop",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ffmpeg_desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://asset.localhost data: blob:; font-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://api.github.com https://gitee.com; media-src 'self' https://asset.localhost blob:; worker-src 'self' blob:;"
    }
  },
  "plugins": {
    "fs": {},
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5RTJGRTUxQ0QxNDlCODkKUldTSm14VE5VZjdpeWNocTJUdHVibUt2MUN6UjNVb28zZGZrM1BqTFNCWTc1UllvVjMwa3l3ZzQK",
      "endpoints": [
        "https://github.com/caoyuee/ffmpeg_desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/256x256@2x.png",
      "icons/512x512.png",
      "icons/512x512@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "config/*"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
